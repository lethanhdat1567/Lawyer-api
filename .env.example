# =============================================================================
# LegalAdvisor AI — API environment template
# Copy to `.env` and fill values. Keys below are every `process.env.*` read in
# this repo (src/, prisma/) plus common Vercel AI SDK provider variables.
# =============================================================================

# --- Runtime ---
# development | production | test
NODE_ENV=development

# HTTP listen port (default 4000 in src/server.ts)
PORT=4000

# --- MySQL / Prisma 7 ---
# Connection string for Prisma Client + prisma.config.ts (migrations).
# Client uses @prisma/adapter-mariadb with this URL at runtime.
DATABASE_URL=mysql://user:password@127.0.0.1:3306/lawyerai

# --- Supabase (Postgres RPC + law_articles table) ---
# Service role key is required for server-side RPC (e.g. match_law_articles).
SUPABASE_URL=https://your-project.supabase.co
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key

# --- JWT (src/services/token.service.ts) ---
# Use JWT_ACCESS_SECRET + JWT_REFRESH_SECRET, or a single JWT_SECRET for both.
JWT_ACCESS_SECRET=change-me-access
JWT_REFRESH_SECRET=change-me-refresh
# JWT_SECRET=change-me-single-secret

# Optional token lifetimes (jsonwebtoken `expiresIn` strings)
JWT_ACCESS_EXPIRES_IN=15m
JWT_REFRESH_EXPIRES_IN=7d

# --- CORS / email links (src/app.ts, src/services/email.service.ts) ---
FRONTEND_URL=http://localhost:3000

# --- SMTP (src/services/email.service.ts) — required in production if sending mail ---
SMTP_HOST=smtp.example.com
SMTP_PORT=587
SMTP_SECURE=false
SMTP_USER=
SMTP_PASS=
EMAIL_FROM=noreply@example.com

# --- Auth flows (src/services/auth.service.ts) ---
EMAIL_VERIFICATION_TTL_HOURS=48
PASSWORD_RESET_TTL_MINUTES=30

# --- Rate limits (src/middlewares/rateLimit.ts) — all optional (defaults in code) ---
# AUTH_RATE_LIMIT_WINDOW_MS=
# AUTH_RATE_LIMIT_MAX=
# RATE_LIMIT_WINDOW_MS=
# RATE_LIMIT_MAX=

# --- Uploads (src/lib/uploadPaths.ts, src/lib/multerImage.ts) ---
# UPLOAD_DIR=
# Max image size in bytes (default 5 MiB)
# UPLOAD_MAX_BYTES=5242880

# --- Firebase Admin (src/lib/firebaseAdmin.ts) — verify Firebase ID tokens ---
FIREBASE_PROJECT_ID=your-project-id
FIREBASE_CLIENT_EMAIL=firebase-adminsdk@your-project.iam.gserviceaccount.com
# Use literal \n for newlines in the key when storing in .env
FIREBASE_PRIVATE_KEY="-----BEGIN PRIVATE KEY-----\n...\n-----END PRIVATE KEY-----\n"

# --- Scheduled DB backup → Google Drive (src/schedules/backupDB.ts) ---
DB_USER=root
DB_PASSWORD=secret
DB_NAME=lawyerai
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
GOOGLE_CLIENT_REFRESH_TOKEN=
GOOGLE_DRIVE_FOLDER_ID=

# --- AI / LLM (Vercel AI SDK `ai` package — not read via process.env in this repo) ---
# Model IDs come from MySQL `schedule_blog_system.model` for chat/blog; fallbacks
# in src/services/ai.service.ts use string IDs such as meta/llama-3.1-8b.
# Set the API key(s) that match your configured providers, for example:
# GOOGLE_GENERATIVE_AI_API_KEY=
# OPENAI_API_KEY=
# AI_GATEWAY_API_KEY=
